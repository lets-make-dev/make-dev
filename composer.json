{
    "name": "make-dev/makedev",
    "description": "Base framework for MakeDev modules — abstract component, transitions, skills, and overlay system.",
    "keywords": ["laravel", "livewire", "modules"],
    "license": "MIT",
    "authors": [
        {
            "name": "Michael Craig",
            "email": "m@ke.dev"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "livewire/livewire": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "MakeDev\\MakeDev\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MakeDev\\MakeDev\\Providers\\MakeDevServiceProvider"
            ]
        }
    }
}
